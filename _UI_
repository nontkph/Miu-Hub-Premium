function Sound(ID, Volume)
	task.defer(function()
		local Sound = Instance.new('Sound', script)
		Sound.SoundId = ID
		repeat task.wait() until Sound.IsLoaded
		Sound.Volume = (Volume or .5)
		Sound:Play()
		game:GetService("Debris"):AddItem(Sound, Sound.TimeLength)
	end)
end

function SwitchPage()
	for textbutton , screen in pairs(Method.Pages) do
		if textbutton == PageSet then
			TweenService:Create(textbutton, TweenInfo.new(.5), {TextTransparency = 0}):Play()
			TweenService:Create(textbutton, TweenInfo.new(.5), { Size = UDim2.new(0 ,textbutton.Size.X.Offset, 0, 30) }):Play()
			screen.Visible = true
		else
			TweenService:Create(textbutton, TweenInfo.new(.5), {TextTransparency = .5}):Play()
			TweenService:Create(textbutton, TweenInfo.new(.5), { Size = UDim2.new(0, textbutton.Size.X.Offset, 0, 25) }):Play()
			screen.Visible = false
		end
	end
end

