				CallBox.Name = "Callback"
				CallBox.Parent = Slide
				CallBox.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				CallBox.BackgroundTransparency = 1.000
				CallBox.Position = UDim2.new(0.813394606, 0, -0.0115714371, 0)
				CallBox.Size = UDim2.new(0, 35, 0, 10)
				CallBox.Font = Enum.Font.SourceSans
				CallBox.PlaceholderText = "number"
				CallBox.Text = Default
				CallBox.TextColor3 = Color3.fromRGB(255, 255, 255)
				CallBox.TextSize = 15.000
				CallBox.TextXAlignment = Enum.TextXAlignment.Right
				
				local SlideStats = {
					Down = false;
					Fire = false;
				};

				--// Method	
				local function Changed()
					local maxSize = Vector2.new( SlideBar.AbsoluteSize.X, SlideBar.AbsoluteSize.Y).X
					local size = Bar.Size.X.Offset
					local num = (size / maxSize)
					local num100 = Max * (size / maxSize)
					if decimals then
						Default = string.format("%.1f", num100)
					else
						Default = math.floor(num100)
					end
					CallBox.Text = Default
					return Callback(Default)
				end
				
				SlideBar.InputBegan:Connect(function(key, pros)
					if pros then return end
					if key.UserInputType == Enum.UserInputType.MouseButton1 then
						Bar.Size = UDim2.new(0, (Mouse.X - Vector2.new(SlideBar.AbsolutePosition.X, SlideBar.AbsolutePosition.Y).X), 1, 0)
						SlideStats.Fire = true
						SlideStats.Down = true
					end
				end)
				
				Mouse.Move:Connect(function()
					if SlideStats.Down == true then
						SlideStats.Fire = false
						SlideStats.Fire = true
						if Mouse.X < Vector2.new(SlideBar.AbsolutePosition.X, SlideBar.AbsolutePosition.Y).X then
							Bar.Size = UDim2.new(0, 0, 1, 0)
						elseif Mouse.X > (Vector2.new(SlideBar.AbsolutePosition.X, SlideBar.AbsolutePosition.Y).X + Vector2.new( SlideBar.AbsoluteSize.X, SlideBar.AbsoluteSize.Y).X) then
							Bar.Size = UDim2.new(0, Vector2.new( SlideBar.AbsoluteSize.X, SlideBar.AbsoluteSize.Y).X, 1, 0)
						else
							Bar.Size = UDim2.new(0, (Mouse.X - Vector2.new(SlideBar.AbsolutePosition.X, SlideBar.AbsolutePosition.Y).X), 1, 0)
						end
					end
				end)
				Bar:GetPropertyChangedSignal("Size"):Connect(function()
					Changed()
				end)
				
				UserInputService.InputEnded:Connect(function(input, gp)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						SlideStats.Down = false
						SlideStats.Fire = false
					end
				end)
				
				CallBox.FocusLost:Connect(function()
					if typeof(tonumber(CallBox.Text)) == "number" then
						local num = tonumber(CallBox.Text)
						if num >= Min and num <= Max then
							Bar.Size = UDim2.new(0, ((num / Max) * Vector2.new( SlideBar.AbsoluteSize.X, SlideBar.AbsoluteSize.Y).X), 1, 0)
						else
							CallBox.Text = string.format("Min [ %s ], Max [ %s ]", Min, Max)
							task.delay(3, function()
								CallBox.Text = Default
							end)
						end
					else
						CallBox.Text =Default
					end
				end)

				
				task.wait(.1)
				ReSize()
				local num = tonumber(CallBox.Text)
				Bar.Size = UDim2.new(0, ((num / Max) * Vector2.new( SlideBar.AbsoluteSize.X, SlideBar.AbsoluteSize.Y).X), 1, 0)
				Changed()
				Slide.LayoutOrder = #Taps["Functions"]
				
				return Sliders
			end
			
			
			function Taps:AddButton(Text, Callback)
				local Buttons = {}
				Buttons.index = Buttons
				
				local Button = Instance.new("TextButton")
				local Title = Instance.new("TextLabel")

				Button.Name = Text
				Button.Parent = Functions
				Button.BackgroundColor3 = Color3.fromRGB(39, 42, 56)
				Button.BorderColor3 = Color3.fromRGB(28, 28, 36)
				Button.LayoutOrder = 2
				Button.Position = UDim2.new(0, 0, 0.512820542, 0)
				Button.Size = UDim2.new(1, 0, 0, 20)
				Button.Font = Enum.Font.SourceSans
				Button.Text = ""
				Button.TextColor3 = Color3.fromRGB(0, 0, 0)
				Button.TextSize = 14.000

				Title.Name = "Title"
				Title.Parent = Button
				Title.AnchorPoint = Vector2.new(0.5, 0.5)
				Title.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				Title.BackgroundTransparency = 1.000
				Title.Position = UDim2.new(0.494245648, 0, 0.467000008, 0)
				Title.Size = UDim2.new(0, 35, 0, 10)
				Title.ZIndex = 2
				Title.Font = Enum.Font.SourceSans
				Title.Text = Text
				Title.TextColor3 = Method.Config.TextColor
				Title.TextSize = 15.000
				
				Button.MouseButton1Click:Connect(function()
					return Callback()
				end)
				
				task.wait(.1)
				ReSize()
				Button.LayoutOrder = #Taps["Functions"]
				
				return Buttons
			end
		
			return Taps
		end
		
		return PageMethod
	end
	
	return Methods
end


return Method
